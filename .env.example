# Proxy target for Ollama requests (only used when the user configures /ollama as their endpoint in Settings).
# Set this to wherever your Ollama instance is reachable from the server.
# OLLAMA_HOST=http://localhost:11434

# Request timeout for Ollama in milliseconds (optional).
# Increase this for slow hardware or large models.
# OLLAMA_TIMEOUT_MS=30000

# Override proxy targets for cloud providers (optional, useful for OpenAI-compatible local APIs).
# ANTHROPIC_HOST=https://api.anthropic.com
# OPENAI_HOST=https://api.openai.com
# GEMINI_HOST=https://generativelanguage.googleapis.com
# MISTRAL_HOST=https://api.mistral.ai

# Directory where documents are stored on disk (optional).
# STORE_DIR=./documents

# Sentry DSN for server-side error reporting (optional).
# SENTRY_DSN=https://…@sentry.io/…
