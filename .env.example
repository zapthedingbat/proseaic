# URL of your Ollama instance.
# For a local install: http://localhost:11434
# For a homelab server: http://<hostname>:11434
OLLAMA_HOST=http://localhost:11434

# Request timeout for Ollama in milliseconds (optional).
# Increase this for slow hardware or large models.
# OLLAMA_TIMEOUT_MS=30000

# Route AI platform requests through the server proxy instead of accessing them directly from the browser.
# Useful when the browser cannot reach the platform (e.g. Ollama on a homelab server, or to centralise logging).
# OLLAMA_PROXY=true
# ANTHROPIC_PROXY=true
# OPENAI_PROXY=true
# GEMINI_PROXY=true
# MISTRAL_PROXY=true

# Override where the server-side proxy forwards requests to (only relevant when proxy is enabled above).
# ANTHROPIC_HOST=https://api.anthropic.com
# OPENAI_HOST=https://api.openai.com
# GEMINI_HOST=https://generativelanguage.googleapis.com
# MISTRAL_HOST=https://api.mistral.ai

# Directory where documents are stored on disk (optional).
# STORE_DIR=./store
