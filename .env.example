# URL of your Ollama instance.
# For a local install: http://localhost:11434
# For a homelab server: http://<hostname>:11434
OLLAMA_HOST=http://localhost:11434

# Request timeout for Ollama in milliseconds (optional).
# Increase this for slow hardware or large models.
# OLLAMA_TIMEOUT_MS=30000

# Override API endpoints (optional — useful for proxies or self-hosted alternatives).
# ANTHROPIC_HOST=https://api.anthropic.com
# OPENAI_HOST=https://api.openai.com
# GEMINI_HOST=https://generativelanguage.googleapis.com
# MISTRAL_HOST=https://api.mistral.ai

# Directory where documents are stored on disk (optional).
# STORE_DIR=./store
