{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "allowArbitraryExtensions": true,
    "lib": ["DOM", "ES2022"],
    "rootDir": "src/browser",
    "outDir": "dist/browser",
    "strict": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "sourceMap": true
  },
  "include": ["src/browser/**/*.ts", "src/browser/**/*.d.ts"],
  "exclude": ["src/browser/**/*.test.ts"]
}
