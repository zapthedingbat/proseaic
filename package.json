  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "dotenv": "^17.4.0",
    "jsdom": "^27.0.1",
    "typescript": "^5.5.4",
    "vitest": "^3.2.4"
  }
}
