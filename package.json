{
  "name": "proseaic",
  "version": "0.1.2",
  "description": "Self-hosted document editor with AI assistance. Model-agnostic and BYOK.",
  "main": "src/server/server.js",
  "type": "module",
  "scripts": {
    "build": "node -r dotenv/config scripts/script.mjs",
    "watch": "node -r dotenv/config scripts/script.mjs",
    "start": "node -r dotenv/config scripts/script.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "playwright test -c playwright.smoke.config.ts",
    "test:smoke:headed": "playwright test -c playwright.smoke.config.ts --headed",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "type-check": "tsc -p tsconfig.ui.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@vscode/codicons": "^0.0.45",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "marked": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.54.2",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.0.0"
  }
}
