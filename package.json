{
  "name": "editor",
  "version": "1.0.0",
  "main": "src/server/server.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:ui",
    "build:ui": "tsc -p tsconfig.ui.json && node scripts/copy-ui-assets.mjs",
    "build:webui": "npm run build:ui",
    "watch:ui": "tsc -p tsconfig.ui.json --watch",
    "watch:webui": "npm run watch:ui",
    "prestart": "npm run build:ui",
    "test": "vitest run --environment jsdom",
    "test:watch": "vitest --environment jsdom",
    "start": "node -r dotenv/config src/server/server.js"
  },
  "keywords": [],
